{
  "name": "synthesis-console",
  "version": "0.5.0",
  "description": "Local dashboard for synthesis engineering — renders project management files as browsable, searchable pages",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "demo": "bun run src/index.ts --demo",
    "autostart:install": "bash scripts/install-autostart-$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/macos/').sh",
    "autostart:uninstall": "bash scripts/uninstall-autostart-$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/macos/').sh"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajivpant/synthesis-console.git"
  },
  "author": "Rajiv Pant",
  "keywords": [
    "synthesis-engineering",
    "project-management",
    "dashboard",
    "markdown",
    "local-first"
  ]
}
